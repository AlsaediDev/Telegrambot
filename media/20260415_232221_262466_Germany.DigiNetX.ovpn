client
dev tun
proto tcp-client
persist-key
persist-tun
tls-client
remote-cert-tls server
verb 3
mute 10


remote Germany.DigiNetx.net 21
remote Germany.DigiNetx.org 37
remote Germany.DigiNetx.net 80
remote Germany.DigiNetx.org 443
remote Germany.DigiiNet.net 3389
remote Germany.DigiiNet.net 1280
remote 87.107.111.23 53


connect-timeout 5
server-poll-timeout 5
connect-retry 1
resolv-retry 60
keepalive 10 60
explicit-exit-notify 2
nobind

auth SHA1
cipher AES-256-CBC
redirect-gateway def1
auth-user-pass 
